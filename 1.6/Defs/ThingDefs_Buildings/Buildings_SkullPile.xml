<?xml version="1.0" encoding="UTF-8"?>

<Defs>

	<!-- Skull Pile -->

	<ThingDef ParentName="BuildingBase">
		<defName>pphhyy_SkullPileI</defName>
		<label>First Skull Pile</label>
		<description>An art piece that can keep being remade to add more skulls.
This one is proper art that gets placed.</description>
		<altitudeLayer>BuildingOnTop</altitudeLayer>
		<passability>PassThroughOnly</passability>
		<selectable>true</selectable>
		<fillPercent>0.20</fillPercent>
		<pathCost>14</pathCost>
		<soundImpactDefault>BulletImpact_Metal</soundImpactDefault>
		<designationCategory>Furniture</designationCategory>
		<rotatable>true</rotatable>
		<size>(1,1)</size>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Building/SkullPiles/FirstSkullPile</texPath>
			<drawSize>(2.9,2.9)</drawSize>
			<drawOffset>(0,0,0.7)</drawOffset>
		</graphicData>
		<minifiedDef>MinifiedThing</minifiedDef>
		<thingCategories>
			<li>BuildingsFurniture</li>
		</thingCategories>
		<statBases>
			<MaxHitPoints>50</MaxHitPoints>
			<Flammability>0.5</Flammability>
			<Mass>3</Mass>
            <TerrorSource>25</TerrorSource>
		</statBases>
		<researchPrerequisites>
			<li>pphhyy_RaiderTech</li>
		</researchPrerequisites>
		<uiIconScale>0.4</uiIconScale>
		<costList>
			<Skull>1</Skull>
			<pphhyy_Scrap>1</pphhyy_Scrap>
		</costList>
	</ThingDef>

