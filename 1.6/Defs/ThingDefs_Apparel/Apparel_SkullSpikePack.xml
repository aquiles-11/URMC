<Defs>

  <ThingDef ParentName="ApparelMakeableBase">
        <defName>pphhyy_FirstBloodSpike</defName>
        <label>first blood spike</label>
        <description>An art piece that can keep being remade to add more skulls.
This one is a backpack.</description>
        <techLevel>Spacer</techLevel>
        <thingClass>Apparel</thingClass>
        <recipeMaker>
          <unfinishedThingDef>UnfinishedPack</unfinishedThingDef>
          <researchPrerequisite>pphhyy_RaiderTech</researchPrerequisite>
          <recipeUsers>
            <li>TableMachining</li>
          </recipeUsers>
          <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
          <workSkill>Crafting</workSkill>
          <effectWorking>Smith</effectWorking>
          <soundWorking>Recipe_Machining</soundWorking>
          <skillRequirements>
            <Crafting>4</Crafting>
          </skillRequirements>
        </recipeMaker>
        <costList>
          <Skull>1</Skull>
          <pphhyy_Scrap>1</pphhyy_Scrap>
        </costList>
        <graphicData>
          <texPath>Gear/SkullSpikes/FirstBloodSpike</texPath>
          <graphicClass>Graphic_Single</graphicClass>
          <drawSize>1.5</drawSize>
        </graphicData>
        <tickerType>Normal</tickerType>
        <statBases>
          <WorkToMake>3200</WorkToMake>
          <Mass>3</Mass>
          <Flammability>0.4</Flammability>
          <EquipDelay>2</EquipDelay>
        </statBases>
        <thingCategories>
          <li>ApparelUtility</li>
        </thingCategories>
        <apparel>
          <countsAsClothingForNudity>false</countsAsClothingForNudity>
          <scoreOffset>4</scoreOffset>
          <careIfWornByCorpse>false</careIfWornByCorpse>
          <careIfDamaged>false</careIfDamaged>
          <wearPerDay>0</wearPerDay>
          <bodyPartGroups>
            <li>Waist</li>
          </bodyPartGroups>
          <layers>
            <li>Belt</li>
          </layers>
          <wornGraphicPath>Gear/SkullSpikes/FirstBloodSpike</wornGraphicPath>
          <wornGraphicData>
            <renderUtilityAsPack>true</renderUtilityAsPack>
            <north>
              <offset>(0,-0.15)</offset>
            </north>
            <south>
              <offset>(0,-0.15)</offset>
            </south>
            <east>
              <offset>(-0.35,-0.1)</offset>
              <thin><offset>(0.05,0)</offset></thin>
              <hulk><offset>(-0.15,0)</offset></hulk>
              <fat> <offset>(-0.20,0)</offset></fat>
            </east>
            <west>
              <offset>(0.35,-0.1)</offset>
              <thin><offset>(-0.05,0)</offset></thin>
              <hulk><offset>(0.15,0)</offset></hulk>
              <fat> <offset>(0.20,0)</offset></fat>
            </west>
            <male>  <scale>(0.75,0.75)</scale></male>
            <female><scale>(0.75,0.75)</scale></female>
            <thin>  <scale>(0.7,0.7)</scale></thin>
            <hulk>  <scale>(0.9,0.9)</scale></hulk>
            <fat>   <scale>(0.9,0.9)</scale></fat>
          </wornGraphicData>
        </apparel>
        <tradeTags>
          <li>ExoticMisc</li>
          <li>Clothing</li>
        </tradeTags>
        <equippedStatOffsets>
            <SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">0.25</SlaveSuppressionOffset>
            <CarryingCapacity>25</CarryingCapacity>
        </equippedStatOffsets>
        <colorGenerator Class="ColorGenerator_Options">
      <options>
        <li>
          <weight>10</weight>
          <only>(95, 99, 76, 255)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(95, 99, 76, 255)</only>
        </li>
        <li>
          <weight>10</weight>
          <only>(95, 99, 76, 255)</only>
        </li>
        <li>
          <weight>6</weight>
          <min>(95, 99, 76, 255)</min>
          <max>(95, 99, 76, 255)</max>
        </li>
      </options>
    </colorGenerator>
      </ThingDef>

