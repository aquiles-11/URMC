<Defs>

<ThingDef Name= "pphhyy_URMC_MarauderHelmets" ParentName= "ArmorHelmetMakeableBase" Abstract= "true">
    <techLevel>Spacer</techLevel>
    <apparel>
      <countsAsClothingForNudity>false</countsAsClothingForNudity>
      <tags>
        <li>Marauder_HatsAndHelmets</li>
      </tags>
      <defaultOutfitTags>
        <li>Soldier</li>
      </defaultOutfitTags>
      <useWornGraphicMask>true</useWornGraphicMask>
      <useDeflectMetalEffect>true</useDeflectMetalEffect>
    </apparel>
  </ThingDef>

<!--__Raider Helmets__-->

<!-- Scrapper Helmet -->

 <ThingDef ParentName="pphhyy_URMC_MarauderHelmets">
    <defName>pphhyy_ScrapperHelmet</defName>
    <label>scrapper helmet</label>
    <description>PLACEHOLDER</description>
    <recipeMaker>
      <researchPrerequisite>pphhyy_RaiderTech</researchPrerequisite>
      <unfinishedThingDef>UnfinishedMetallicTechArmor</unfinishedThingDef>
      <skillRequirements>
        <Crafting>5</Crafting>
      </skillRequirements>
      <recipeUsers Inherit="false">
        <li>TableMachining</li>
      </recipeUsers>
    </recipeMaker>
    <graphicData>
      <texPath>HelmetsAndHats/ScrapperHelmet/ScrapperHelmet</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>1.5</drawSize>
    </graphicData>
    <equippedStatOffsets>
      <SlaveSuppressionOffset MayRequire="Ludeon.RimWorld.Ideology">0.05</SlaveSuppressionOffset>
      <Flammability>-0.25</Flammability>
    </equippedStatOffsets>
    <statBases>
      <WorkToMake>8000</WorkToMake>
      <MaxHitPoints>120</MaxHitPoints>
      <Mass>1.2</Mass>
      <ArmorRating_Sharp>0.63</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.3</ArmorRating_Blunt>
      <ArmorRating_Heat>0.42</ArmorRating_Heat>
      <Insulation_Cold>4</Insulation_Cold>
      <Insulation_Heat>2</Insulation_Heat>
      <EquipDelay>3</EquipDelay>
    </statBases>
    <costList>
      <pphhyy_Scrap>1</pphhyy_Scrap>
    </costList>
    <apparel>
      <tags>
        <li>Raider_ScrapperHelmet</li>
      </tags>
      <bodyPartGroups>
        <li>UpperHead</li>
      </bodyPartGroups>
      <wornGraphicPath>HelmetsAndHats/ScrapperHelmet/ScrapperHelmet</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
    </apparel>
    <tradeTags>
      <li>Armor</li>
    </tradeTags>
  </ThingDef>

