  <RecipeDef>
    <defName>pphhyy_Enforcer</defName>
    <label>make enforcer armor</label>
    <description>PLACEHOLDER</description>
    <jobString>Making an Enforcer Armor.</jobString>
    <workAmount>60000</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <effectWorking>Smith</effectWorking>
    <soundWorking>Recipe_Smith</soundWorking>
    <workSkill>Crafting</workSkill>
    <unfinishedThingDef>UnfinishedTechArmor</unfinishedThingDef>
    <researchPrerequisite>pphhyy_RaiderTech</researchPrerequisite>
    <skillRequirements>
      <Crafting>7</Crafting>
    </skillRequirements>
    <recipeUsers>
      <li>TableMachining</li>
    </recipeUsers>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>pphhyy_RaiderArmor</li>
            <li>pphhyy_TorchRatArmor</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>pphhyy_Scrap</li>
          </thingDefs>
        </filter>
        <count>8</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
